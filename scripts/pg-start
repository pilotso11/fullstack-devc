#!/bin/bash
set -euo pipefail

DB_USER="${DATABASE_USER:-postgres}"
DB_PASS="${DATABASE_PASSWORD:-postgres}"
DB_URL="${DATABASE_URL:-postgresql://postgres:postgres@localhost:5432/postgres}"

# Parse database name from DATABASE_URL path component
_after_scheme="${DB_URL#*://}"
if [[ "$_after_scheme" == *"/"* ]]; then
    _path="${_after_scheme#*/}"
    DB_NAME="${_path%%\?*}"
else
    DB_NAME=""
fi
DB_NAME="${DB_NAME:-postgres}"

PGDATA="/var/lib/postgresql/17/main"
PG_CONF="/etc/postgresql/17/main"

# Already running?
if pg_isready -q 2>/dev/null; then
    echo "PostgreSQL 17 is already running."
    exit 0
fi

# Initialize cluster if data directory is missing
if ! sudo -u postgres test -f "$PGDATA/PG_VERSION"; then
    echo "Initializing PostgreSQL 17 cluster..."
    sudo mkdir -p "$PGDATA" "$PG_CONF" /var/log/postgresql
    sudo chown postgres:postgres "$PGDATA" "$PG_CONF" /var/log/postgresql
    sudo -u postgres /usr/lib/postgresql/17/bin/initdb -D "$PGDATA" \
        --auth-local=peer --auth-host=scram-sha-256

    # Write pg_hba.conf for container use
    sudo tee "$PGDATA/pg_hba.conf" > /dev/null <<'PGEOF'
# TYPE  DATABASE  USER  ADDRESS       METHOD
local   all       all                 peer
host    all       all   127.0.0.1/32  scram-sha-256
host    all       all   ::1/128       scram-sha-256
host    all       all   0.0.0.0/0     scram-sha-256
host    all       all   ::/0          scram-sha-256
PGEOF
    sudo chown postgres:postgres "$PGDATA/pg_hba.conf"

    # Configure listen_addresses
    sudo -u postgres sed -i "s/^#\?listen_addresses.*/listen_addresses = '*'/" "$PGDATA/postgresql.conf"

    # Point pg_ctlcluster at the data directory
    sudo tee "$PG_CONF/postgresql.conf" > /dev/null <<PGEOF
data_directory = '$PGDATA'
PGEOF
fi

# Start PostgreSQL
echo "Starting PostgreSQL 17..."
sudo pg_ctlcluster 17 main start

# Wait for ready (up to 30 seconds)
for i in $(seq 1 30); do
    pg_isready -q 2>/dev/null && break
    sleep 1
done

if ! pg_isready -q 2>/dev/null; then
    echo "ERROR: PostgreSQL failed to start within 30 seconds."
    echo "Check logs: /var/log/postgresql/postgresql-17-main.log"
    exit 1
fi

# Create or update role using escaped SQL (avoids psql variable interpolation warnings)
_escaped_pass=$(printf '%s' "$DB_PASS" | sed "s/'/''/g")

if [ "$DB_USER" = "postgres" ]; then
    sudo -u postgres psql -c "ALTER ROLE postgres WITH PASSWORD '${_escaped_pass}'" 2>/dev/null
else
    _role_exists=$(sudo -u postgres psql -tAc "SELECT 1 FROM pg_roles WHERE rolname = '$(printf '%s' "$DB_USER" | sed "s/'/''/g")'")
    if [ "$_role_exists" != "1" ]; then
        echo "Creating role '$DB_USER'..."
        sudo -u postgres createuser --login "$DB_USER"
    fi
    sudo -u postgres psql -c "ALTER ROLE \"$DB_USER\" WITH PASSWORD '${_escaped_pass}'" 2>/dev/null
fi

# Create database if not using default 'postgres'
if [ "$DB_NAME" != "postgres" ]; then
    _db_exists=$(sudo -u postgres psql -tAc "SELECT 1 FROM pg_database WHERE datname = '$(printf '%s' "$DB_NAME" | sed "s/'/''/g")'")
    if [ "$_db_exists" != "1" ]; then
        echo "Creating database '$DB_NAME'..."
        sudo -u postgres createdb -O "$DB_USER" "$DB_NAME"
    fi
fi

echo ""
echo "PostgreSQL 17 is ready."
echo "  User:     $DB_USER"
echo "  Database: $DB_NAME"
echo "  Port:     5432"
# Mask password in URL for display
_display_url=$(echo "$DB_URL" | sed 's|://[^:]*:[^@]*@|://***:***@|')
echo "  URL:      $_display_url"
